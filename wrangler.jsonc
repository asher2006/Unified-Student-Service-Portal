{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ussp-backend",
  "compatibility_date": "2025-09-27",
  "main": "server/src/index.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "client/dist"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
